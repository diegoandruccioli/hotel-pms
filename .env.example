# ============================================================
# Hotel PMS — Environment Variables Reference
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ---------------------------------------------------------------
# REQUIRED — Security (generate strong random values for production)
# ---------------------------------------------------------------

# Shared HMAC secret for internal service authentication.
# Must be at least 32 characters. Generate with:
#   openssl rand -base64 48
INTERNAL_HMAC_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_48

# JWT signing secret (HS256). Must be at least 32 characters.
# Generate with: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_48

# ---------------------------------------------------------------
# REQUIRED — Database
# ---------------------------------------------------------------

# PostgreSQL superuser password (used by all services)
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password

# ---------------------------------------------------------------
# REQUIRED — Config Server
# ---------------------------------------------------------------

# Password for the Spring Cloud Config Server HTTP basic auth
CONFIG_SERVER_PASSWORD=CHANGE_ME_config_server_password

# ---------------------------------------------------------------
# REQUIRED — Portale Alloggiati Web (Polizia di Stato)
# These are required for the Italian guest registration compliance feature.
# Obtain credentials from: https://alloggiatiweb.poliziadistato.it
# ---------------------------------------------------------------

# Portal username (e.g. HOTELALFA01)
ALLOGGIATI_USERNAME=YOUR_PS_USERNAME

# Portal password
ALLOGGIATI_PASSWORD=YOUR_PS_PASSWORD

# Web Service Key (account → "Chiave Web Service" → "Genera nuova chiave")
ALLOGGIATI_WS_KEY=YOUR_WS_KEY

# Set to false ONLY in production after successful dry-run validation
# true  = calls "Test" endpoint (validates but does not record permanently)
# false = calls "Send" endpoint (records definitively in PS archive)
ALLOGGIATI_DRY_RUN=true

# Encrypts per-hotel Alloggiati Web credentials at rest (hotel_settings table).
# Used only when a hotel configures its own credentials from the UI instead of
# relying on the ALLOGGIATI_USERNAME/PASSWORD/WS_KEY fallback above.
# encryption-key: any secret string, e.g. `openssl rand -base64 32`
# encryption-salt: MUST be hex-encoded, e.g. `openssl rand -hex 16`
ALLOGGIATI_CREDENTIALS_ENCRYPTION_KEY=CHANGE_ME_generate_with_openssl_rand_base64_32
ALLOGGIATI_CREDENTIALS_ENCRYPTION_SALT=CHANGE_ME_generate_with_openssl_rand_hex_16

# ---------------------------------------------------------------
# OPTIONAL — Overrides (defaults are sufficient for standard deployments)
# ---------------------------------------------------------------

# CORS allowed origins (comma-separated, no trailing slash)
# Default: http://localhost:5173
# GW_CORS_ALLOWED_ORIGINS=https://pms.yourhotel.com

# Alloggiati SOAP endpoint (default: official PS portal)
# ALLOGGIATI_SERVICE_URL=https://alloggiatiweb.poliziadistato.it/service/Service.asmx

# SOAP namespace (default: inferred from WSDL)
# ALLOGGIATI_WS_NAMESPACE=http://alloggiatiweb.poliziadistato.it/PortaleAlloggiati/Service/
