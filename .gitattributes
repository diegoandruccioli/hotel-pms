# Enforce LF line endings
* text eol=lf

# Ensure UTF-8 encoding
* charset=utf-8

# Binary files must never go through line-ending normalization — the blanket
# "* text eol=lf" rule above would otherwise treat them as text and corrupt
# them the next time Git touches them (checkout, add, stash, etc.).
*.jar binary
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
*.pdf binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.zip binary
