<?xml version="1.0" encoding="UTF-8"?>
<!--
  GAP-4: Audit-log aggregation — Loki appender attivo solo nel profilo Docker
  (SPRING_PROFILES_ACTIVE=auth-service).  In test e sviluppo locale resta solo
  il ConsoleAppender standard di Spring Boot.
-->
<configuration>

  <!-- Valori di default Spring Boot (CONSOLE_LOG_PATTERN, LOG_LEVEL_PATTERN, ecc.) -->
  <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

  <!-- Legge spring.application.name dall'environment Spring -->
  <springProperty scope="context" name="appName"
                  source="spring.application.name"
                  defaultValue="auth-service"/>

  <!-- ── ConsoleAppender (sempre attivo) ──────────────────────────────────── -->
  <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
    <encoder>
      <pattern>${CONSOLE_LOG_PATTERN}</pattern>
      <charset>UTF-8</charset>
    </encoder>
  </appender>

  <!-- ── LokiAppender — attivo solo nel profilo Docker (auth-service) ─────── -->
  <springProfile name="auth-service">

    <appender name="LOKI" class="com.github.loki4j.logback.Loki4jAppender">
      <http>
        <!-- LOKI_URL iniettato da docker-compose; fallback per sviluppo locale -->
        <url>${LOKI_URL:-http://loki:3100}/loki/api/v1/push</url>
      </http>
      <format>
        <!-- Label Loki: usate in Grafana per filtrare per servizio e livello -->
        <label>
          <pattern>service=${appName},level=%level</pattern>
        </label>
        <!-- Corpo del log inviato a Loki -->
        <message>
          <pattern>[%level] [%thread] %logger{36} | %msg%n%ex</pattern>
        </message>
        <sortByTime>true</sortByTime>
      </format>
    </appender>

    <!-- AsyncAppender: non blocca mai i thread applicativi anche se Loki e' irraggiungibile -->
    <appender name="LOKI_ASYNC" class="ch.qos.logback.classic.AsyncAppender">
      <appender-ref ref="LOKI"/>
      <queueSize>512</queueSize>
      <discardingThreshold>0</discardingThreshold>
      <neverBlock>true</neverBlock>
    </appender>

    <root level="INFO">
      <appender-ref ref="CONSOLE"/>
      <appender-ref ref="LOKI_ASYNC"/>
    </root>

  </springProfile>

  <!-- ── Profilo default: test / sviluppo locale — solo console ───────────── -->
  <springProfile name="!auth-service">
    <root level="INFO">
      <appender-ref ref="CONSOLE"/>
    </root>
  </springProfile>

</configuration>
