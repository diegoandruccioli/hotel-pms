<?xml version="1.0" encoding="UTF-8"?>
<!--
  Project-specific SpotBugs exclusions for billing-service.

  EI_EXPOSE_REP2 on RedisNonceStore: the StringRedisTemplate field is a
  Spring-managed singleton injected via constructor DI (T-GW-08 anti-replay
  nonce store). A defensive copy is not applicable for a shared Redis client
  bean — the same instance is intentionally reused across requests. This
  pattern is idiomatic in Spring Boot.
-->
<FindBugsFilter
        xmlns="https://github.com/spotbugs/filter/3.0.0"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="https://github.com/spotbugs/filter/3.0.0 https://raw.githubusercontent.com/spotbugs/spotbugs/3.1.0/spotbugs/etc/findbugsfilter.xsd">
    <Match>
        <Class name="com.hotelpms.billing.security.RedisNonceStore"/>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>
</FindBugsFilter>
