{
  "info": {
    "_postman_id": "1a2b3c4d-5e6f-7a8b-9c0d-1e2f3a4b5c6d",
    "name": "Enterprise Hotel PMS API",
    "description": "API Integration points for the Enterprise Hotel Microservices ecosystem routed through the API Gateway (localhost:8080).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Auth Service",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"testuser\",\n  \"email\": \"test@hotel.com\",\n  \"password\": \"Password123!\"\n}"
            },
            "url": {
              "raw": "http://localhost:8080/api/v1/auth/register",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "v1", "auth", "register"]
            }
          }
        },
        {
          "name": "Login User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.token) {",
                  "    pm.environment.set(\"jwt_token\", jsonData.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin\"\n}"
            },
            "url": {
              "raw": "http://localhost:8080/api/v1/auth/login",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "v1", "auth", "login"]
            }
          }
        },
        {
          "name": "Validate Token",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "url": {
              "raw": "http://localhost:8080/api/v1/auth/validate",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "v1", "auth", "validate"]
            }
          }
        }
      ]
    },
    {
      "name": "2. Guest Service",
      "item": [
        {
          "name": "Create Guest",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Jane\",\n  \"lastName\": \"Doe\",\n  \"email\": \"jane.doe@example.com\",\n  \"phone\": \"+1-555-987-6543\"\n}"
            },
            "url": {
              "raw": "http://localhost:8080/api/v1/guests",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "v1", "guests"]
            }
          }
        },
        {
          "name": "Get All Guests",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "url": {
              "raw": "http://localhost:8080/api/v1/guests",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "v1", "guests"]
            }
          }
        }
      ]
    },
    {
      "name": "3. Booking & Stay Services",
      "item": [
        {
          "name": "Create Reservation",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"guestName\": \"Jane Doe\",\n  \"checkInDate\": \"2026-03-05\",\n  \"checkOutDate\": \"2026-03-10\",\n  \"status\": \"CONFIRMED\",\n  \"lineItems\": [\n    {\n      \"roomId\": \"bbbbbbbb-bbbb-bbbb-bbbb-bbbbbbbbbbbb\",\n      \"price\": 120.00\n    }\n  ]\n}"
            },
            "url": {
              "raw": "http://localhost:8080/api/v1/reservations",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "v1", "reservations"]
            }
          }
        },
        {
          "name": "Check-In (Create Stay)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reservationId\": \"REPLACE_WITH_UUID\",\n  \"guestId\": \"REPLACE_WITH_UUID\",\n  \"roomId\": \"bbbbbbbb-bbbb-bbbb-bbbb-bbbbbbbbbbbb\",\n  \"status\": \"CHECKED_IN\"\n}"
            },
            "url": {
              "raw": "http://localhost:8080/api/v1/stays",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "v1", "stays"]
            }
          }
        }
      ]
    },
    {
      "name": "4. F&B Service",
      "item": [
        {
          "name": "Create F&B Order",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"stayId\": \"REPLACE_WITH_STAY_UUID\",\n  \"items\": [\n    {\n      \"itemName\": \"Classic Beef Burger\",\n      \"quantity\": 2,\n      \"unitPrice\": 15.00\n    },\n    {\n      \"itemName\": \"Local Draft IPA\",\n      \"quantity\": 2,\n      \"unitPrice\": 8.00\n    }\n  ]\n}"
            },
            "url": {
              "raw": "http://localhost:8080/api/v1/orders",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "v1", "orders"]
            }
          }
        }
      ]
    },
    {
      "name": "5. Billing Service",
      "item": [
        {
          "name": "Generate Invoice",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "url": {
              "raw": "http://localhost:8080/api/v1/invoices/generate/REPLACE_WITH_STAY_UUID",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": [
                "api",
                "v1",
                "invoices",
                "generate",
                "REPLACE_WITH_STAY_UUID"
              ]
            }
          }
        },
        {
          "name": "Mark Invoice Paid",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "url": {
              "raw": "http://localhost:8080/api/v1/invoices/REPLACE_WITH_INVOICE_UUID/pay",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": [
                "api",
                "v1",
                "invoices",
                "REPLACE_WITH_INVOICE_UUID",
                "pay"
              ]
            }
          }
        }
      ]
    }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [""]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [""]
      }
    }
  ],
  "variable": [
    {
      "key": "jwt_token",
      "value": "",
