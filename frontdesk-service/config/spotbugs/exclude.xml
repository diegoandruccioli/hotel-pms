<?xml version="1.0" encoding="UTF-8"?>
<!--
  Project-specific SpotBugs exclusions for frontdesk-service.

  EI_EXPOSE_REP2 on AlloggiatiWebSenderServiceImpl:
  The RestOperations field is a Spring-managed singleton injected via constructor DI.
  A defensive copy is not applicable for HTTP client beans — the same shared instance
  is intentionally reused across requests. This pattern is idiomatic in Spring Boot.
-->
<FindBugsFilter
        xmlns="https://github.com/spotbugs/filter/3.0.0"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="https://github.com/spotbugs/filter/3.0.0 https://raw.githubusercontent.com/spotbugs/spotbugs/3.1.0/spotbugs/etc/findbugsfilter.xsd">
    <Match>
        <Class name="com.hotelpms.frontdesk.stays.service.impl.AlloggiatiWebSenderServiceImpl"/>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>
</FindBugsFilter>
